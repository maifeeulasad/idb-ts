{
  "name": "idb-ts-example",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "npx esbuild index.ts --bundle --platform=browser --format=esm --external:tslib --outfile=index.js --servedir=. --serve=8000 --watch",
    "build": "npx esbuild index.ts --bundle --platform=browser --format=esm --external:tslib --outfile=index.js && mkdir -p build/typescript && cp index.html index.js build/typescript"
  },
  "author": "Maifee Ul Asad <maifeeulasad@gmail.com>",
  "license": "MIT",
  "description": "",
  "dependencies": {
    "idb-ts": "^3.13.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.8",
    "esbuild": "^0.25.0",
    "typescript": "^5.2"
  },
  "type": "module"
}
